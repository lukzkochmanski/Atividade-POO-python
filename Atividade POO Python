class Livro:
    def __init__(self, titulo, genero, autor):
        self.titulo = titulo
        self.genero = genero
        self.autor = autor

    def emprestar(self):
        return f"O livro {self.titulo}, {self.genero}, de {self.autor} foi emprestado."

    def devolver(self):
        return f"O livro {self.titulo}, {self.genero}, de {self.autor} foi devolvido."


livro1 = Livro("O Homem Sussurro", "Suspense/Terror/Ficção Policial", "Alex North")
livro2 = Livro("O Pequeno Príncipe", "Literatura Infantil/Fantasia Cienífica", "Antoine de Saint-Exupéry")
livro3 = Livro("O Amor Não é Óbvio", "Romance Juvenil", "Elayne Baeta")


print(livro1.devolver())
print(livro2.devolver())
print(livro3.emprestar()) 
